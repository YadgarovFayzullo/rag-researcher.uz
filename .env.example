# LLM (облачный OpenAI-совместимый провайдер)
LLM_BASE_URL=https://api.openai.com/v1
LLM_API_KEY=sk-...
LLM_MODEL=gpt-4o-mini

# Embeddings (OpenAI text-embedding-3-small → 1536 измерений)
EMBED_BASE_URL=https://api.openai.com/v1
EMBED_API_KEY=sk-...
EMBED_MODEL=text-embedding-3-small
EMBED_DIM=1536

# Qdrant
QDRANT_URL=
QDRANT_HOST=localhost
QDRANT_PORT=6333
QDRANT_API_KEY=
QDRANT_COLLECTION=tenant_posts

# Supabase
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your-anon-or-service-key

# Langfuse
LANGFUSE_ENABLED=true
LANGFUSE_PUBLIC_KEY=pk-lf-...
LANGFUSE_SECRET_KEY=sk-lf-...
LANGFUSE_BASE_URL=https://cloud.langfuse.com

# RAG / API
SEARCH_LIMIT=5
SCORE_THRESHOLD=0.5
API_HOST=0.0.0.0
API_PORT=8000

# CORS: список origin'ов через запятую (напр. https://app.example.com), либо * для всех
CORS_ORIGINS=*
